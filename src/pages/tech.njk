---
layout: base.njk
title: Tech — AETHER
description: How AETHER builds — real-time 3D, motion systems, design tokens, performance and accessibility as craft.
---

    <section class="page-hero container">
      <div class="page-hero__light deco"></div>
      <span class="eyebrow page-hero__eyebrow" data-reveal="fade" data-en="{{ tech.hero.eyebrow.en }}" data-de="{{ tech.hero.eyebrow.de }}">{{ tech.hero.eyebrow.en }}</span>
      <h1 class="page-hero__title ink-shine" data-reveal data-en="{{ tech.hero.title.en }}" data-de="{{ tech.hero.title.de }}">{{ tech.hero.title.en }}</h1>
      <p class="page-hero__lead" data-reveal data-en="{{ tech.hero.lead.en }}" data-de="{{ tech.hero.lead.de }}">{{ tech.hero.lead.en }}</p>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow" data-en="{{ tech.stack.eyebrow.en }}" data-de="{{ tech.stack.eyebrow.de }}">{{ tech.stack.eyebrow.en }}</span>
          <h2 class="section-head__title" data-en="{{ tech.stack.title.en }}" data-de="{{ tech.stack.title.de }}">{{ tech.stack.title.en }}</h2>
        </div>
        <div class="grid-3" data-reveal-group="90">
          {%- for c in tech.stack.cards %}
          <article class="card" data-reveal><span class="card__num">0{{ loop.index }}</span><h3 class="card__title" data-en="{{ c.title.en }}" data-de="{{ c.title.de }}">{{ c.title.en }}</h3><p class="card__text" data-en="{{ c.text.en }}" data-de="{{ c.text.de }}">{{ c.text.en }}</p></article>
          {%- endfor %}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-head" data-reveal>
          <span class="eyebrow" data-en="{{ tech.principles.eyebrow.en }}" data-de="{{ tech.principles.eyebrow.de }}">{{ tech.principles.eyebrow.en }}</span>
          <h2 class="section-head__title" data-en="{{ tech.principles.title.en }}" data-de="{{ tech.principles.title.de }}">{{ tech.principles.title.en }}</h2>
        </div>
        <div class="steps" data-reveal-group="110">
          {%- for step in tech.principles.steps %}
          <div class="step" data-reveal><span class="step__no">{{ step.no }}</span><div><h3 class="step__title" data-en="{{ step.title.en }}" data-de="{{ step.title.de }}">{{ step.title.en }}</h3><p class="step__text" data-en="{{ step.text.en }}" data-de="{{ step.text.de }}">{{ step.text.en }}</p></div></div>
          {%- endfor %}
        </div>
        <div style="margin-top:var(--s-7)" data-reveal><span class="placeholder" data-en="{{ tech.lab.en }}" data-de="{{ tech.lab.de }}">{{ tech.lab.en }}</span></div>
      </div>
    </section>
